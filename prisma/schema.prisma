// Prisma Client Generator
generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

// Database Connection
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --------------------------------------
// ENUMS
// --------------------------------------

enum Role {
  SUPER_ADMIN
  VENDOR
  STAFF
  USER
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PENDING
  CONFIRMED
  PROCESSING
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  COMPLETED
  CANCELLED
  REFUND_REQUESTED
  REFUNDED
  FAILED
  RETURNED
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  PARTIALLY_PAID
  REFUNDED
}

enum POSPaymentStatus {
  PAID
  PARTIAL
  DUE
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE_BANKING
  ONLINE
  MIXED
}

enum ProductType {
  PHYSICAL
  DIGITAL
  SERVICE
}

enum StockStatus {
  IN_STOCK
  OUT_OF_STOCK
  LOW_STOCK
}

enum AttributeDataType {
  TEXT
  NUMBER
  DECIMAL
  BOOLEAN
  DATE
  DROPDOWN
  MULTI_SELECT
  COLOR
  IMAGE_OPTION
  FILE_OPTION
  DIMENSION
  WEIGHT
  CUSTOM
}

enum AttributeUIType {
  INPUT
  TEXTAREA
  DROPDOWN
  RADIO
  CHECKBOX
  COLOR_SWATCH
  IMAGE_SWATCH
  BUTTON_SELECTOR
  SLIDER
  RANGE
  TAG_SELECTOR
}

// --------------------------------------
// USER & AUTHENTICATION
// --------------------------------------

model User {
  id        String  @id @default(uuid()) // Supabase UUID
  email     String  @unique
  fullName  String?
  phone     String?
  avatarUrl String?
  role      Role    @default(USER)
  status    Boolean @default(true)

  // Vendor Relation
  vendor   Vendor? @relation(fields: [vendorId], references: [id])
  vendorId String?

  // Relations
  orders   Order[]
  reviews  Review[]
  wishlist Wishlist[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// --------------------------------------
// VENDOR MANAGEMENT
// --------------------------------------

model Vendor {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  logo        String?
  banner      String?
  description String?

  // Contact Info
  email   String
  phone   String
  address String

  // Financials
  commissionRate Float @default(0) // Percentage
  balance        Float @default(0)

  // Status
  isVerified Boolean @default(false)
  isActive   Boolean @default(true)

  // Relations
  users    User[]
  products Product[]
  expenses Expense[]
  payouts  Payout[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("vendors")
}

model Payout {
  id            String  @id @default(uuid())
  vendorId      String
  amount        Float
  status        String  @default("PENDING") // PENDING, COMPLETED
  transactionId String?
  note          String?

  vendor Vendor @relation(fields: [vendorId], references: [id])

  createdAt DateTime @default(now())

  @@map("payouts")
}

// --------------------------------------
// PRODUCT MANAGEMENT
// --------------------------------------

model Category {
  id          String  @id @default(uuid())
  name        String
  shortCode   String? @map("short_code")
  slug        String  @unique
  image       String?
  description String?
  parentId    String?
  isActive    Boolean @default(true) // Add this line

  sortOrder Int @default(0) @map("sort_order")

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  // Relations to Attributes
  attributes    CategoryAttribute[]
  specTemplates SpecTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status String? @default("ACTIVE")

  @@index([name])
  @@index([parentId, isActive])
  @@map("categories")
}

// --------------------------------------
// ATTRIBUTES
// --------------------------------------

model Attribute {
  id           String             @id @default(uuid())
  name         String
  slug         String             @unique
  description  String?
  dataType     AttributeDataType  @default(TEXT) @map("data_type")
  uiType       AttributeUIType    @default(INPUT) @map("ui_type")
  
  // Configurations
  isVariant    Boolean @default(false) @map("is_variant")
  isFilterable Boolean @default(true) @map("is_filterable")
  isSearchable Boolean @default(true) @map("is_searchable")
  status       String  @default("ACTIVE") // ACTIVE, INACTIVE

  values           AttributeValue[]
  categoryMappings CategoryAttribute[]
  productMappings  ProductAttribute[]
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("attributes")
}

model AttributeValue {
  id           String  @id @default(uuid())
  attributeId  String  @map("attribute_id")
  label        String
  value        String
  shortCode    String? @map("short_code") // e.g., "BLK" for Black (Used for SKU)
  colorCode    String? @map("color_code") // For COLOR type
  imageUrl     String? @map("image_url") // For IMAGE_OPTION type
  metadata     Json?   // Extra config
  displayOrder Int     @default(0) @map("display_order")

  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  
  productMappings ProductAttributeValue[]
  variantMappings VariantAttributeValue[]

  @@map("attribute_values")
}

model CategoryAttribute {
  categoryId   String  @map("category_id")
  attributeId  String  @map("attribute_id")
  isRequired   Boolean @default(false) @map("is_required")
  displayOrder Int     @default(0) @map("display_order")

  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@id([categoryId, attributeId])
  @@map("category_attributes")
}

model ProductAttribute {
  id          String @id @default(uuid())
  productId   String @map("product_id")
  attributeId String @map("attribute_id")
  
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  
  values ProductAttributeValue[]

  @@unique([productId, attributeId])
  @@map("product_attributes")
}

model ProductAttributeValue {
  productAttributeId String @map("product_attribute_id")
  attributeValueId   String @map("attribute_value_id")

  productAttribute ProductAttribute @relation(fields: [productAttributeId], references: [id], onDelete: Cascade)
  attributeValue   AttributeValue   @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@id([productAttributeId, attributeValueId])
  @@map("product_attribute_values")
}

model VariantAttributeValue {
  variantId        String @map("variant_id")
  attributeValueId String @map("attribute_value_id")

  variant        Variant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValue AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@id([variantId, attributeValueId])
  @@map("variant_attribute_values")
}

model VariantMedia {
  id          String  @id @default(uuid())
  variantId   String  @map("variant_id")
  url         String
  type        String  @default("IMAGE") // IMAGE, VIDEO, 360
  isMain      Boolean @default(false) @map("is_main")
  displayOrder Int    @default(0) @map("display_order")

  variant Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("variant_media")
}

model Product {
  id         String  @id @default(uuid())
  vendorId   String? // Nullable for Admin products
  categoryId String
  brandId    String?

  name        String
  slug        String   @unique
  description String?  @db.Text
  shortDesc   String?
  images      String[]
  videoUrl    String?

  // Pricing
  price          Float
  offerPrice     Float?
  onlinePrice    Float?
  wholesalePrice Float?
  taxClass       String?
  costPrice      Float   @default(0)
  model          String?

  // Inventory
  sku                String? @unique
  barcode            String?
  stock              Int     @default(0)
  trackInventory     Boolean @default(true)
  trackSerials       Boolean @default(false)
  trackExpiry        Boolean @default(false)
  trackBatch         Boolean @default(false)
  trackWarranty      Boolean @default(false)
  minStock           Int     @default(5) // Low stock alert
  maxStock           Int     @default(100)
  reorderPoint       Int     @default(10)
  defaultWarehouseId String?
  defaultSupplierId  String?

  // Attributes
  type               ProductType            @default(PHYSICAL)
  productVariantType String                 @default("simple") // "simple" or "variable"
  isFeatured         Boolean                @default(false)
  status             ProductLifecycleStatus @default(ACTIVE)
  isFlashSale        Boolean                @default(false)
  isBestSeller       Boolean                @default(false) @map("is_best_seller")

  // Counters
  viewCount Int @default(0) @map("view_count")
  soldCount Int @default(0) @map("sold_count")

  // Sale / Campaign
  discountPercentage Float?    @map("discount_percentage")
  flashSaleEndTime   DateTime? @map("flash_sale_end_time")
  campaignId         String?   @map("campaign_id")
  campaign           Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  // Additional Details
  unit           String? // e.g. "pc", "kg"
  warrantyMonths Int?    @default(0)
  warrantyType   String? // e.g. "Official", "Service"

  // JSON Data
  specifications Json? // Key-value pairs: { "RAM": "8GB", "Color": "Black" }
  attributes     Json? // Defined attributes: [{ id: "1", name: "Color", values: ["Red", "Blue"] }]
  faqs           Json? // Array of { question, answer }

  // Relations
  vendor        Vendor?        @relation(fields: [vendorId], references: [id])
  category      Category       @relation(fields: [categoryId], references: [id])
  brand         Brand?         @relation(fields: [brandId], references: [id])
  variants      Variant[]
  reviews       Review[]
  orderItems    OrderItem[]
  returnItems   ReturnItem[]
  wishlist      Wishlist[]
  specs         ProductSpec[]
  productImages ProductImage[]
  stockHistory  StockHistory[]
  productAttributes ProductAttribute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lastPurchaseCost       Float                   @default(0) @map("last_purchase_cost")
  reservedStock          Int                     @default(0) @map("reserved_stock")
  safetyStock            Int                     @default(0) @map("safety_stock")
  reorderQty             Int                     @default(0) @map("reorder_qty")
  leadTimeDays           Int                     @default(0) @map("lead_time_days")
  seoTitle               String?                 @map("seo_title")
  metaDescription        String?                 @map("meta_description")
  tags                   String[]
  stockAdjustments       StockAdjustmentItem[]
  stockLedgers           StockLedger[]
  goodsReceiveNoteItems  GoodsReceiveNoteItem[]
  purchaseOrderItems     PurchaseOrderItem[]
  purchaseReturnItems    PurchaseReturnItem[]
  warehouseTransferItems WarehouseTransferItem[]
  productAuditLogs       ProductAuditLog[]
  supplierProducts       SupplierProduct[]

  @@index([name])
  @@index([categoryId, status])
  @@index([status, isFlashSale])
  @@index([status, isBestSeller])
  @@index([status, isFeatured])
  @@index([status, soldCount])
  @@index([status, viewCount])
  @@index([status, createdAt])
  @@index([brandId])
  @@index([status, price])
  @@index([status, offerPrice])
  @@map("products")
}

model ProductImage {
  id           String  @id @default(uuid())
  productId    String  @map("product_id")
  url          String
  publicId     String? @map("public_id")
  isThumbnail  Boolean @default(false) @map("is_thumbnail")
  displayOrder Int     @default(0) @map("display_order")
  altText      String? @map("alt_text")

  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  variants Variant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, displayOrder])
  @@index([productId, isThumbnail])
  @@map("product_images")
}

model Brand {
  id         String    @id @default(uuid())
  name       String
  shortCode  String?   @map("short_code")
  slug       String    @unique
  logo       String?
  isFeatured Boolean   @default(false) @map("is_featured")
  products   Product[]

  @@index([name])
  @@map("brands")
}

// --------------------------------------
// CAMPAIGNS
// --------------------------------------

model Campaign {
  id          String    @id @default(uuid())
  title       String
  subtitle    String?
  bannerImage String?   @map("banner_image")
  ctaLink     String?   @map("cta_link")
  isActive    Boolean   @default(true) @map("is_active")
  priority    Int       @default(0)
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")

  products Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("campaigns")
}

model Variant {
  id         String  @id @default(uuid())
  productId  String
  name       String // e.g. "Red-XL"
  sku        String?
  upc        String? // Barcode / UPC
  price      Float
  costPrice  Float   @default(0)
  expense    Float   @default(0)
  offerPrice Float?
  stock      Int     @default(0)
  minStock   Int     @default(5)
  hasSerial  Boolean @default(false)
  image      String?
  imageAlt   String? @map("image_alt")

  // Image Relation
  productImageId String?       @map("product_image_id")
  productImage   ProductImage? @relation(fields: [productImageId], references: [id])

  // Specific attributes (JSON for flexibility)
  attributes Json? // { color: "Red", size: "XL" }

  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  serials      ProductSerial[]
  orderItems   OrderItem[]
  returnItems  ReturnItem[]
  stockHistory StockHistory[]
  variantAttributes VariantAttributeValue[]
  media        VariantMedia[]

  lastPurchaseCost       Float                   @default(0) @map("last_purchase_cost")
  stockAdjustments       StockAdjustmentItem[]
  stockLedgers           StockLedger[]
  goodsReceiveNoteItems  GoodsReceiveNoteItem[]
  purchaseOrderItems     PurchaseOrderItem[]
  purchaseReturnItems    PurchaseReturnItem[]
  warehouseTransferItems WarehouseTransferItem[]

  @@map("product_variants")
}

// --------------------------------------
// SALES & ORDERS (Online + POS)
// --------------------------------------

model Order {
  id            String  @id @default(uuid())
  orderNumber   String  @unique @map("order_number")
  userId        String? @map("user_id")
  trackingToken String  @unique @default(uuid()) @map("tracking_token")

  // Customer
  customerName  String? @map("customer_name")
  customerPhone String? @map("customer_phone")
  customerEmail String? @map("customer_email")

  // Delivery
  shippingAddress   String?   @map("shipping_address")
  division          String?
  district          String?
  upazila           String?
  orderNote         String?   @map("order_note")
  estimatedDelivery DateTime? @map("estimated_delivery")
  shippedAt         DateTime? @map("shipped_at")
  deliveredAt       DateTime? @map("delivered_at")
  cancelledAt       DateTime? @map("cancelled_at")
  cancelReason      String?   @map("cancel_reason")

  // Pricing
  subTotal       Float   @default(0) @map("sub_total")
  totalAmount    Float   @default(0) @map("total_amount")
  discount       Float   @default(0)
  couponCode     String? @map("coupon_code")
  couponDiscount Float   @default(0) @map("coupon_discount")
  tax            Float   @default(0)
  shippingCost   Float   @default(0) @map("shipping_cost")
  grandTotal     Float   @default(0) @map("grand_total")

  // Payment
  paymentMethod  PaymentMethod @map("payment_method")
  paymentStatus  PaymentStatus @default(UNPAID) @map("payment_status")
  transactionId  String?       @map("transaction_id")
  mobileProvider String?       @map("mobile_provider")
  mobileNumber   String?       @map("mobile_number")
  refundAmount   Float?        @map("refund_amount")
  refundNote     String?       @map("refund_note")

  // Status
  status       OrderStatus @default(PENDING)
  internalNote String?     @map("internal_note")
  ipAddress    String?     @map("ip_address")

  // POS
  isPos            Boolean           @default(false) @map("is_pos")
  cashierId        String?           @map("cashier_id")
  cashPayment      Float?            @map("cash_payment")
  cardPayment      Float?            @map("card_payment")
  mobilePayment    Float?            @map("mobile_payment")
  posPaymentStatus POSPaymentStatus? @map("pos_payment_status")
  paidAmount       Float?            @default(0) @map("paid_amount")
  dueAmount        Float?            @default(0) @map("due_amount")

  // Relations
  user          User?          @relation(fields: [userId], references: [id])
  items         OrderItem[]
  payments      OrderPayment[]
  returns       Return[]
  events        OrderEvent[]
  posCustomer   POSCustomer?   @relation(fields: [posCustomerId], references: [id])
  posCustomerId String?        @map("pos_customer_id")
  guarantor     Guarantor?

  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  Customer   Customer? @relation(fields: [customerId], references: [id])
  customerId String?

  @@index([trackingToken])
  @@index([customerPhone])
  @@index([status])
  @@index([createdAt])
  @@index([isPos, paymentStatus, createdAt])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String   @map("order_id")
  productId   String   @map("product_id")
  variantId   String?  @map("variant_id")
  productName String   @map("product_name")
  quantity    Int
  unitPrice   Float    @map("unit_price")
  total       Float
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])
  variant     Variant? @relation(fields: [variantId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("order_items")
}

model OrderPayment {
  id      String        @id @default(uuid())
  orderId String        @map("order_id")
  method  PaymentMethod
  amount  Float

  // Method specific details
  provider      String? // For Mobile Banking (bKash, Nagad, etc.) or Card Brand
  transactionId String? @map("transaction_id")
  phoneNumber   String? @map("phone_number") // For Mobile Banking
  note          String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("order_payments")
}

// --------------------------------------
// EXPENSE MANAGEMENT
// --------------------------------------

model ExpenseCategory {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  icon        String? // emoji or icon name
  color       String? // hex color for badge
  description String? @db.Text
  isActive    Boolean @default(true) @map("is_active")

  expenses Expense[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("expense_categories")
}

model Expense {
  id         String  @id @default(uuid())
  vendorId   String? @map("vendor_id")
  categoryId String  @map("category_id")

  title         String
  amount        Float
  date          DateTime @default(now())
  note          String?  @db.Text
  attachment    String? // receipt image URL
  reference     String? // receipt/reference number
  paymentMethod String   @default("CASH") @map("payment_method") // CASH, CARD, MOBILE_BANKING, BANK_TRANSFER
  paidTo        String?  @map("paid_to")
  isRecurring   Boolean  @default(false) @map("is_recurring")

  vendor   Vendor?         @relation(fields: [vendorId], references: [id])
  category ExpenseCategory @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("expenses")
}

// --------------------------------------
// STAFF MANAGEMENT & SALARY
// --------------------------------------

model Staff {
  id               String   @id @default(uuid())
  name             String
  phone            String   @unique
  email            String?
  role             String?  @default("Cashier") // Admin, Manager, Cashier, Staff
  permissions      String?  @map("permissions") @db.Text // JSON array of permission keys
  joiningDate      DateTime @default(now()) @map("joining_date")
  baseSalary       Float    @default(0) @map("base_salary")
  isActive         Boolean  @default(true) @map("is_active")
  address          String?
  nidNumber        String?  @map("nid_number")
  emergencyContact String?  @map("emergency_contact")

  salaries StaffSalary[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("staff_members")
}

model StaffSalary {
  id            String    @id @default(uuid())
  staffId       String    @map("staff_id")
  month         Int // 1-12
  year          Int
  basicSalary   Float     @map("basic_salary")
  overtime      Float     @default(0)
  bonus         Float     @default(0)
  deduction     Float     @default(0)
  advance       Float     @default(0)
  netSalary     Float     @map("net_salary")
  paidAmount    Float     @default(0) @map("paid_amount")
  dueAmount     Float     @default(0) @map("due_amount")
  paymentMethod String?   @map("payment_method")
  paymentDate   DateTime? @map("payment_date")
  status        String    @default("PENDING") // PENDING, PAID, PARTIAL
  note          String?

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([staffId, month, year])
  @@map("staff_salaries")
}

// --------------------------------------
// REVIEWS & WISHLIST
// --------------------------------------

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model Review {
  id           String       @id @default(uuid())
  productId    String
  userId       String?
  orderId      String?
  name         String
  email        String?
  rating       Int
  reviewText   String       @map("review_text") @db.Text
  status       ReviewStatus @default(PENDING)
  isVerified   Boolean      @default(false) @map("is_verified")
  helpfulCount Int          @default(0) @map("helpful_count")
  adminNote    String?      @map("admin_note")

  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  user         User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  images       ReviewImage[]
  helpfulVotes ReviewHelpful[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, status])
  @@index([userId])
  @@map("reviews")
}

model ReviewImage {
  id       String @id @default(uuid())
  reviewId String @map("review_id")
  imageUrl String @map("image_url")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("review_images")
}

model ReviewHelpful {
  id       String @id @default(uuid())
  reviewId String @map("review_id")
  userIp   String @map("user_ip")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([reviewId, userIp])
  @@map("review_helpful")
}

model Wishlist {
  id        String @id @default(uuid())
  userId    String
  productId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlist")
}

// --------------------------------------
// SETTINGS
// --------------------------------------

model Setting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   @db.Text
  category    String   @default("general") // general, pos, invoice, store, payments, notifications, appearance, security
  description String?
  updatedBy   String?  @map("updated_by") // email or user id
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@index([category])
  @@map("settings")
}

// --------------------------------------
// AUDIT LOG
// --------------------------------------

model AuditLog {
  id          String   @id @default(uuid())
  entity      String // 'setting', 'staff', 'product', etc.
  entityId    String?  @map("entity_id")
  action      String // 'create', 'update', 'delete'
  changes     String   @db.Text // JSON diff
  performedBy String?  @map("performed_by") // user email
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([entity, entityId])
  @@index([performedBy])
  @@map("audit_logs")
}

model ProductSerial {
  id           String       @id @default(uuid())
  variantId    String
  serialNumber String
  status       SerialStatus @default(AVAILABLE)

  // Sales Info
  isSold  Boolean   @default(false)
  soldAt  DateTime?
  orderId String? // Link to order if sold

  variant Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([variantId, serialNumber])
  @@map("product_serials")
}

enum SerialStatus {
  AVAILABLE
  SOLD
  DEFECTIVE
  RETURNED
  TRANSFERRED
}

model SpecTemplate {
  id         String @id @default(uuid())
  categoryId String @map("category_id")
  name       String
  sortOrder  Int    @default(0) @map("sort_order")

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("spec_templates")
}

model SavedSpecTemplate {
  id   String   @id @default(uuid())
  name String   @unique
  keys String[] // Array of strings e.g. ["Processor", "RAM"]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("saved_spec_templates")
}

model ProductSpec {
  id        String @id @default(uuid())
  productId String @map("product_id")
  name      String
  value     String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_specs")
}

model StockHistory {
  id        String  @id @default(uuid())
  productId String  @map("product_id")
  variantId String? @map("variant_id")

  action        StockAction
  quantity      Int
  previousStock Int         @map("previous_stock")
  newStock      Int         @map("new_stock")

  reason String? // Purchase, Damage, Return, Manual, POS correction
  note   String?
  source String? // POS, Online, Manual, User

  product Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant Variant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  createdBy String?  @map("created_by") // User ID
  createdAt DateTime @default(now())

  @@map("stock_history")
}

enum StockAction {
  ADD
  REDUCE
  ADJUST
}

// --------------------------------------
// RETURNS & REFUNDS
// --------------------------------------

model Return {
  id           String       @id @default(uuid())
  returnNumber String       @unique @map("return_number")
  orderId      String       @map("order_id")
  reason       String
  status       ReturnStatus @default(PENDING)
  refundAmount Float        @map("refund_amount")
  processedBy  String?      @map("processed_by") // Cashier/Staff ID
  note         String?

  order Order        @relation(fields: [orderId], references: [id])
  items ReturnItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("returns")
}

model ReturnItem {
  id        String  @id @default(uuid())
  returnId  String  @map("return_id")
  productId String  @map("product_id")
  variantId String? @map("variant_id")
  quantity  Int
  unitPrice Float   @map("unit_price")
  total     Float

  return  Return   @relation(fields: [returnId], references: [id], onDelete: Cascade)
  product Product  @relation(fields: [productId], references: [id])
  variant Variant? @relation(fields: [variantId], references: [id])

  @@map("return_items")
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

// --------------------------------------
// POS CUSTOMER DATABASE
// --------------------------------------

model POSCustomer {
  id      String  @id @default(uuid())
  name    String
  phone   String  @unique
  email   String?
  address String?

  orders Order[]

  totalPurchase Float @default(0) @map("total_purchase")
  totalDue      Float @default(0) @map("total_due")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pos_customers")
}

// --------------------------------------
// GUARANTOR
// --------------------------------------

model Guarantor {
  id       String  @id @default(uuid())
  orderId  String  @unique @map("order_id")
  name     String
  phone    String
  relation String?
  address  String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("guarantors")
}

// --------------------------------------
// DUE PAYMENTS
// --------------------------------------

model DuePayment {
  id      String  @id @default(uuid())
  orderId String  @map("order_id")
  amount  Float
  paidBy  String? @map("paid_by")
  note    String?

  createdAt DateTime @default(now()) @map("created_at")

  @@map("due_payments")
}

// --------------------------------------
// ORDER LIFECYCLE — EVENTS & SECURITY
// --------------------------------------

model OrderEvent {
  id               String  @id @default(uuid())
  orderId          String  @map("order_id")
  eventType        String  @map("event_type") // STATUS_CHANGE | PAYMENT_UPDATE | NOTE_ADDED | CANCELLED | REFUND_REQUESTED
  oldStatus        String? @map("old_status")
  newStatus        String? @map("new_status")
  oldPaymentStatus String? @map("old_payment_status")
  newPaymentStatus String? @map("new_payment_status")
  changedBy        String? @map("changed_by") // email | 'system' | 'admin'
  note             String?
  metadata         Json? // extra data (e.g. tracking URL, refund amount)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@map("order_events")
}

model IpRateLimit {
  id           String    @id @default(uuid())
  ipAddress    String    @map("ip_address")
  action       String // 'order_create' | 'coupon_apply' | 'payment_retry' | 'track'
  count        Int       @default(1)
  windowStart  DateTime  @default(now()) @map("window_start")
  blockedUntil DateTime? @map("blocked_until")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([ipAddress, action])
  @@map("ip_rate_limits")
}

// --------------------------------------
// SUPPLIER / PURCHASE VENDOR MANAGEMENT
// --------------------------------------

enum PurchaseStatus {
  DRAFT
  CONFIRMED
  PARTIAL
  PAID
  CANCELLED
}

model Supplier {
  id          String  @id @default(uuid())
  name        String
  companyName String? @map("company_name")
  phone       String
  address     String?
  notes       String? @db.Text
  isActive    Boolean @default(true) @map("is_active")

  purchases Purchase[]
  payments  SupplierPayment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  supplierCode     String?            @unique @map("supplier_code")
  email            String?
  district         String?
  country          String?
  contactPerson    String?            @map("contact_person")
  tradeLicenseNo   String?            @map("trade_license_no")
  binNumber        String?            @map("bin_number")
  tinNumber        String?            @map("tin_number")
  status           SupplierStatus     @default(ACTIVE)
  openingBalance   Float              @default(0) @map("opening_balance")
  purchaseOrders   PurchaseOrder[]
  grns             GoodsReceiveNote[]
  supplierLedgers  SupplierLedger[]
  supplierProducts SupplierProduct[]
  PurchaseReturn   PurchaseReturn[]

  @@map("suppliers")
}

model Purchase {
  id            String   @id @default(uuid())
  supplierId    String   @map("supplier_id")
  invoiceNumber String   @unique @map("invoice_number")
  date          DateTime @default(now())

  totalAmount Float @default(0) @map("total_amount")
  paidAmount  Float @default(0) @map("paid_amount")
  dueAmount   Float @default(0) @map("due_amount")
  discount    Float @default(0)

  status     PurchaseStatus @default(CONFIRMED)
  note       String?        @db.Text
  attachment String? // voucher/receipt image URL

  supplier Supplier       @relation(fields: [supplierId], references: [id])
  items    PurchaseItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("purchases")
}

model PurchaseItem {
  id         String @id @default(uuid())
  purchaseId String @map("purchase_id")
  productId  String @map("product_id")

  quantity  Int
  costPrice Float @map("cost_price")
  subtotal  Float

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("purchase_items")
}

model SupplierPayment {
  id            String  @id @default(uuid())
  supplierId    String  @map("supplier_id")
  amount        Float
  paymentMethod String  @default("CASH") @map("payment_method")
  note          String? @db.Text

  supplier Supplier @relation(fields: [supplierId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@map("supplier_payments")
}

enum ProductLifecycleStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  ACTIVE
  ARCHIVED
  DISCONTINUED
  COMING_SOON
  OUT_OF_STOCK
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum WarehouseType {
  MAIN
  STORE
  TRANSIT
  DAMAGE
}

enum StockAdjustmentReason {
  DAMAGE
  COUNT
  THEFT
  EXPIRED
}

enum StockAdjustmentStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum TransferStatus {
  DRAFT
  APPROVED
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

enum GRNStatus {
  DRAFT
  RECEIVED
  REJECTED
  PARTIAL
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
  CANCELLED
}

enum PurchaseReturnStatus {
  DRAFT
  APPROVED
  RETURNED
  CLOSED
  CANCELLED
}

// --------------------------------------
// WAREHOUSE & INVENTORY
// --------------------------------------

model Warehouse {
  id        String        @id @default(uuid())
  name      String
  code      String        @unique
  type      WarehouseType @default(MAIN)
  address   String?
  isActive  Boolean       @default(true) @map("is_active")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at")

  stockAdjustments  StockAdjustment[]
  stockLedgers      StockLedger[]
  goodsReceiveNotes GoodsReceiveNote[]
  purchaseOrders    PurchaseOrder[]
  purchaseReturns   PurchaseReturn[]
  transfersFrom     WarehouseTransfer[] @relation("warehouseTransfersSourceIdToWarehouse")
  transfersTo       WarehouseTransfer[] @relation("warehouseTransfersDestinationIdToWarehouse")

  @@map("warehouses")
}

model StockAdjustment {
  id               String                @id @default(uuid())
  adjustmentNumber String                @unique @map("adjustment_number")
  date             DateTime              @default(now())
  warehouseId      String                @map("warehouse_id")
  reason           StockAdjustmentReason
  status           StockAdjustmentStatus @default(DRAFT)
  note             String?
  approvedBy       String?               @map("approved_by")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @default(now()) @updatedAt @map("updated_at")

  warehouse Warehouse             @relation(fields: [warehouseId], references: [id])
  items     StockAdjustmentItem[]

  @@map("stock_adjustments")
}

model StockAdjustmentItem {
  id                String   @id @default(uuid())
  stockAdjustmentId String   @map("stock_adjustment_id")
  productId         String   @map("product_id")
  variantId         String?  @map("variant_id")
  quantity          Int
  unitCost          Float    @default(0) @map("unit_cost")
  createdAt         DateTime @default(now()) @map("created_at")

  stockAdjustment StockAdjustment @relation(fields: [stockAdjustmentId], references: [id], onDelete: Cascade)
  product         Product         @relation(fields: [productId], references: [id])
  variant         Variant?        @relation(fields: [variantId], references: [id])

  @@map("stock_adjustment_items")
}

model StockLedger {
  id            String   @id @default(uuid())
  warehouseId   String   @map("warehouse_id")
  productId     String   @map("product_id")
  variantId     String?  @map("variant_id")
  inQty         Int      @default(0) @map("in_qty")
  outQty        Int      @default(0) @map("out_qty")
  balanceQty    Int      @map("balance_qty")
  unitCost      Float    @default(0) @map("unit_cost")
  totalValue    Float    @default(0) @map("total_value")
  referenceType String   @map("reference_type")
  referenceId   String   @map("reference_id")
  note          String?
  createdAt     DateTime @default(now()) @map("created_at")

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])
  variant   Variant?  @relation(fields: [variantId], references: [id])

  @@map("stock_ledgers")
}

model WarehouseTransfer {
  id             String         @id @default(uuid())
  transferNumber String         @unique @map("transfer_number")
  date           DateTime       @default(now())
  sourceId       String         @map("source_id")
  destinationId  String         @map("destination_id")
  status         TransferStatus @default(DRAFT)
  note           String?
  dispatchedBy   String?        @map("dispatched_by")
  receivedBy     String?        @map("received_by")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @default(now()) @updatedAt @map("updated_at")

  sourceWarehouse Warehouse               @relation("warehouseTransfersSourceIdToWarehouse", fields: [sourceId], references: [id])
  destWarehouse   Warehouse               @relation("warehouseTransfersDestinationIdToWarehouse", fields: [destinationId], references: [id])
  items           WarehouseTransferItem[]

  @@map("warehouse_transfers")
}

model WarehouseTransferItem {
  id                  String   @id @default(uuid())
  warehouseTransferId String   @map("warehouse_transfer_id")
  productId           String   @map("product_id")
  variantId           String?  @map("variant_id")
  quantity            Int
  unitCost            Float    @default(0) @map("unit_cost")
  createdAt           DateTime @default(now()) @map("created_at")

  warehouseTransfer WarehouseTransfer @relation(fields: [warehouseTransferId], references: [id], onDelete: Cascade)
  product           Product           @relation(fields: [productId], references: [id])
  variant           Variant?          @relation(fields: [variantId], references: [id])

  @@map("warehouse_transfer_items")
}

model GoodsReceiveNote {
  id              String    @id @default(uuid())
  grnNumber       String    @unique @map("grn_number")
  purchaseOrderId String    @map("purchase_order_id")
  supplierId      String    @map("supplier_id")
  warehouseId     String    @map("warehouse_id")
  receivedDate    DateTime  @default(now()) @map("received_date")
  status          GRNStatus @default(DRAFT)
  note            String?
  attachment      String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  purchaseOrder PurchaseOrder          @relation(fields: [purchaseOrderId], references: [id])
  supplier      Supplier               @relation(fields: [supplierId], references: [id])
  warehouse     Warehouse              @relation(fields: [warehouseId], references: [id])
  items         GoodsReceiveNoteItem[]

  @@map("goods_receive_notes")
}

model GoodsReceiveNoteItem {
  id           String   @id @default(uuid())
  grnId        String   @map("grn_id")
  productId    String   @map("product_id")
  variantId    String?  @map("variant_id")
  receivedQty  Int      @map("received_qty")
  rejectedQty  Int      @default(0) @map("rejected_qty")
  acceptedQty  Int      @map("accepted_qty")
  unitCost     Float    @default(0) @map("unit_cost")
  batchNumber  String?  @map("batch_number")
  imei         String?
  serialNumber String?  @map("serial_number")
  createdAt    DateTime @default(now()) @map("created_at")

  goodsReceiveNote GoodsReceiveNote @relation(fields: [grnId], references: [id], onDelete: Cascade)
  product          Product          @relation(fields: [productId], references: [id])
  variant          Variant?         @relation(fields: [variantId], references: [id])

  @@map("goods_receive_note_items")
}

model PurchaseOrder {
  id                   String              @id @default(uuid())
  poNumber             String              @unique @map("po_number")
  supplierId           String              @map("supplier_id")
  warehouseId          String?             @map("warehouse_id")
  date                 DateTime            @default(now())
  expectedDeliveryDate DateTime?           @map("expected_delivery_date")
  totalAmount          Float               @default(0) @map("total_amount")
  discount             Float               @default(0)
  tax                  Float               @default(0)
  shippingCost         Float               @default(0) @map("shipping_cost")
  otherCost            Float               @default(0) @map("other_cost")
  grandTotal           Float               @default(0) @map("grand_total")
  status               PurchaseOrderStatus @default(DRAFT)
  note                 String?
  attachment           String?
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @default(now()) @updatedAt @map("updated_at")

  supplier          Supplier            @relation(fields: [supplierId], references: [id])
  warehouse         Warehouse?          @relation(fields: [warehouseId], references: [id])
  items             PurchaseOrderItem[]
  goodsReceiveNotes GoodsReceiveNote[]
  purchaseReturns   PurchaseReturn[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String   @id @default(uuid())
  purchaseOrderId String   @map("purchase_order_id")
  productId       String   @map("product_id")
  variantId       String?  @map("variant_id")
  quantity        Int
  receivedQty     Int      @default(0) @map("received_qty")
  unitCost        Float    @map("unit_cost")
  discount        Float    @default(0)
  tax             Float    @default(0)
  subtotal        Float
  createdAt       DateTime @default(now()) @map("created_at")

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])
  variant       Variant?      @relation(fields: [variantId], references: [id])

  @@map("purchase_order_items")
}

model PurchaseReturn {
  id              String               @id @default(uuid())
  returnNumber    String               @unique @map("return_number")
  supplierId      String               @map("supplier_id")
  purchaseOrderId String               @map("purchase_order_id")
  warehouseId     String               @map("warehouse_id")
  date            DateTime             @default(now())
  status          PurchaseReturnStatus @default(DRAFT)
  reason          String?
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @default(now()) @updatedAt @map("updated_at")

  supplier      Supplier             @relation(fields: [supplierId], references: [id])
  purchaseOrder PurchaseOrder        @relation(fields: [purchaseOrderId], references: [id])
  warehouse     Warehouse            @relation(fields: [warehouseId], references: [id])
  items         PurchaseReturnItem[]

  @@map("purchase_returns")
}

model PurchaseReturnItem {
  id               String  @id @default(uuid())
  purchaseReturnId String  @map("purchase_return_id")
  productId        String  @map("product_id")
  variantId        String? @map("variant_id")
  returnQty        Int     @map("return_qty")
  unitCost         Float   @map("unit_cost")

  purchaseReturn PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)
  product        Product        @relation(fields: [productId], references: [id])
  variant        Variant?       @relation(fields: [variantId], references: [id])

  @@map("purchase_return_items")
}

model SupplierLedger {
  id             String   @id @default(uuid())
  supplierId     String   @map("supplier_id")
  type           String
  debit          Float    @default(0)
  credit         Float    @default(0)
  runningBalance Float    @map("running_balance")
  referenceId    String?  @map("reference_id")
  note           String?
  date           DateTime @default(now())
  createdAt      DateTime @default(now()) @map("created_at")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@map("supplier_ledgers")
}

model SupplierProduct {
  id         String   @id @default(uuid())
  supplierId String   @map("supplier_id")
  productId  String   @map("product_id")
  price      Float    @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([supplierId, productId])
  @@map("supplier_products")
}

model ProductAuditLog {
  id            String   @id @default(uuid())
  productId     String   @map("product_id")
  action        String
  changedBy     String?  @map("changed_by")
  changedFields Json?    @map("changed_fields")
  note          String?
  createdAt     DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
  @@map("product_audit_logs")
}

model CustomerLedger {
  id             String   @id @default(uuid())
  customerId     String   @map("customer_id")
  type           String
  debit          Float    @default(0)
  credit         Float    @default(0)
  runningBalance Float    @map("running_balance")
  referenceId    String?  @map("reference_id")
  note           String?
  date           DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_ledgers")
}

// --------------------------------------
// ACCOUNTING
// --------------------------------------

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
  COGS
}

model FiscalYear {
  id        String   @id @default(uuid())
  name      String   @unique
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  isClosed  Boolean  @default(false) @map("is_closed")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  periods AccountingPeriod[]

  @@map("fiscal_years")
}

model AccountingPeriod {
  id           String   @id @default(uuid())
  fiscalYearId String   @map("fiscal_year_id")
  name         String
  startDate    DateTime @map("start_date")
  endDate      DateTime @map("end_date")
  isClosed     Boolean  @default(false) @map("is_closed")
  createdAt    DateTime @default(now()) @map("created_at")

  fiscalYear     FiscalYear     @relation(fields: [fiscalYearId], references: [id])
  journalEntries JournalEntry[]

  @@map("accounting_periods")
}

model ChartOfAccount {
  id                String             @id @default(uuid())
  code              String             @unique
  name              String
  type              AccountType
  isSystem          Boolean            @default(false) @map("is_system")
  balance           Float              @default(0)
  journalEntryItems JournalEntryItem[]

  @@map("chart_of_accounts")
}

model JournalEntry {
  id                 String   @id @default(uuid())
  entryNumber        String   @unique @map("entry_number")
  date               DateTime @default(now())
  reference          String?
  note               String?
  accountingPeriodId String?  @map("accounting_period_id")

  accountingPeriod  AccountingPeriod?  @relation(fields: [accountingPeriodId], references: [id])
  journalEntryItems JournalEntryItem[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("journal_entries")
}

model JournalEntryItem {
  id             String  @id @default(uuid())
  journalEntryId String  @map("journal_entry_id")
  accountId      String  @map("account_id")
  debit          Float   @default(0)
  credit         Float   @default(0)
  description    String?

  journalEntry   JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  chartOfAccount ChartOfAccount @relation(fields: [accountId], references: [id])

  @@map("journal_entry_items")
}

model Customer {
  id             String   @id @default(uuid())
  customerCode   String   @unique @map("customer_code")
  name           String
  phone          String?
  email          String?
  address        String?
  companyName    String?  @map("company_name")
  taxId          String?  @map("tax_id")
  customerGroup  String   @default("RETAIL") @map("customer_group")
  openingBalance Float    @default(0) @map("opening_balance")
  balance        Float    @default(0)
  creditLimit    Float    @default(0) @map("credit_limit")
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  customerLedgers CustomerLedger[]
  orders          Order[]

  @@map("customers")
}

// --------------------------------------
// AI PRODUCT INTELLIGENCE ENGINE
// --------------------------------------

model AiGenerationDraft {
  id              String   @id @default(uuid())
  adminId         String?  // Who initiated this
  status          String   @default("PENDING") // PENDING, REVIEWED, ACCEPTED, REJECTED
  
  // Inputs
  productName     String?
  sourceUrls      String[]
  imageUrls       String[]
  
  // Extracted/Generated Data (JSON structured with Confidence Scores & Sources)
  description     Json?    
  shortDesc       Json?
  specifications  Json?    
  attributes      Json?
  variants        Json?
  tags            Json?
  seoData         Json?    
  faqs            Json?
  highlights      Json?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("ai_generation_drafts")
}

model AiLearningLog {
  id              String   @id @default(uuid())
  field           String   // e.g., "shortDesc", "seoTitle", "colorAttribute"
  suggestedValue  String   @db.Text
  acceptedValue   String   @db.Text
  action          String   // "ACCEPTED_AS_IS", "EDITED", "REJECTED"
  createdAt       DateTime @default(now())

  @@map("ai_learning_logs")
}
